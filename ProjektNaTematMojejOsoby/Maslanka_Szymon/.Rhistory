library(plotly)
model <- lm(Średni_wzrost_synów ~ Wzrost_ojca + Wzrost_matki, data = b)
model |> summary()
model |> tidy() |> knitr::kable()
model |>
summarise(n = n(), mean = mean(.resid))
model$residuals |> shapiro.test()
model |> augment()
model |> glance()
